{
  "$schema": "./blueprint-schema.json",
  "meta": {
    "title": "Default Nextcloud Playground Blueprint",
    "author": "nextcloud-playground",
    "description": "Baseline browser blueprint for Nextcloud Playground."
  },
  "debug": { "enabled": false },
  "landingPage": "/index.php/apps/files/files",
