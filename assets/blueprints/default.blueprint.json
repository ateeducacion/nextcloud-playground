    "username": "admin",
    "password": "admin",
    "email": "admin@example.com"
  },
  "apps": [],
  "steps": [
    { "step": "disableApp", "app": "firstrunwizard" },
    { "step": "setConfig", "app": "core", "key": "whatsNewEnabled", "value": "no" }
  ]
}
